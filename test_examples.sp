/**
 * Adds numbers.
 * @param {number} a
 * @param {number} b
 * @return {number}
 * @example
 * set r = add(1, 2)
 * console.show(r)
 */
define add = (a, b) => a + b

/**
 * Greets.
 * @param {string} name
 * @example
 * define hello = () => {
 *     console.show(greet("Alice"))
 * }
 */
define greet = (name) => "Hello, " + name